# ════════════════════════════════════════════════════
# Sahabat Aksara — Environment Configuration
# Copy ke .env dan isi nilai sesuai environment
# ════════════════════════════════════════════════════

# ─── Supabase (WAJIB) ──────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key-or-service-role-key

# ─── CORS Origins (comma-separated) ──────────────────
# Development:
#   CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Production:
#   CORS_ORIGINS=https://sahabataksara.app,https://www.sahabataksara.app
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ─── Server ─────────────────────────────────────────
HOST=0.0.0.0
PORT=8001

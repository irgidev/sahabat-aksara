# ════════════════════════════════════════════════════
# Sahabat Aksara — Frontend Environment
# ════════════════════════════════════════════════════

# ─── Supabase (WAJIB) ──────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ─── Development Mode ───────────────────────────────
# Set 'true' untuk enable default student fallback (dev only!)
# Set 'false' atau hapus untuk production
VITE_DEV_MODE=true

# ─── API Base URL (optional, default: localhost:8001) ─
# VITE_API_BASE_URL=https://api.sahabataksara.app
